# =============================================================================
# FPT Admission API — Environment variables
# Copy: cp docker/.env.example docker/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=2222
LOG_LEVEL=debug

# JWT (bắt buộc ≥ 32 ký tự)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# CORS — danh sách origin cách nhau bởi dấu phẩy (không dùng khi NODE_ENV=development, API cho phép *)
CORS_ORIGINS=http://localhost:2222,http://localhost:3000

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=fpt_admission_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=1111

# Khi chạy API trên máy host + DB trong Docker (task up + task dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:1111/fpt_admission_dev

# Khi chạy full stack Docker (profile app hoặc prod compose), DATABASE_URL được
# ghi đè trong docker-compose — không cần sửa tay.

# -----------------------------------------------------------------------------
# Production (docker-compose.prod.yml — local hoặc Dokploy UI)
# Khớp image GitHub Actions: ${DOCKER_USERNAME}/fpt-admission-api
# -----------------------------------------------------------------------------
# DOCKER_USERNAME=your-dockerhub-username
# APP_TAG=latest
# NODE_ENV=production
# PORT=2222
# LOG_LEVEL=info
# JWT_SECRET=<production-secret-32+chars>
# CORS_ORIGINS=https://your-frontend.com
# POSTGRES_DB=fpt_admission_prod
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=change-me-strong-password
# POSTGRES_PORT=1111

# -----------------------------------------------------------------------------
# Khác (tùy chọn)
# -----------------------------------------------------------------------------
# API_KEY=your-api-key
