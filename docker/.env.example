# =============================================================================
# FPT Admission API — Environment variables
# Copy: cp docker/.env.example docker/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=2222
LOG_LEVEL=debug

# JWT (bắt buộc ≥ 32 ký tự)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# CORS — danh sách origin cách nhau bởi dấu phẩy (không dùng khi NODE_ENV=development, API cho phép *)
CORS_ORIGINS=http://localhost:2222,http://localhost:3333

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=fpt_admission_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=1111
# POSTGRES_CONTAINER=fpt-postgres-dev

# Khi chạy API trên máy host + DB trong Docker (task up + task dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:1111/fpt_admission_dev

# -----------------------------------------------------------------------------
# Adminer (dev) — http://localhost:4444
# System: PostgreSQL | Server: postgres:1111 | User/Pass: postgres
# Database: fpt_admission_dev  (không để trống — không chọn DB "postgres")
# -----------------------------------------------------------------------------
ADMINER_PORT=4444

# Image API: chỉ GitHub Actions build/push — không build/push trên máy dev.
# Prod (Dokploy): docker-compose.prod.yml pull image từ Docker Hub.

# Production (Dokploy): DOCKER_USERNAME, JWT_SECRET, CORS_ORIGINS, POSTGRES_* — xem docs/DEPLOY.md

# -----------------------------------------------------------------------------
# Khác (tùy chọn)
# -----------------------------------------------------------------------------
# API_KEY=your-api-key
